# Michibiki configuration
# Copy to .env and fill in values

# AniList API token (get from https://anilist.co/settings/developer)
# Create a client, then visit:
# https://anilist.co/api/v2/oauth/authorize?client_id=YOUR_CLIENT_ID&response_type=token
ANILIST_TOKEN=your_token_here

# Suwayomi GraphQL endpoint (Docker internal DNS)
SUWAYOMI_URL=http://suwayomi:4567/api/graphql

# Sync interval in seconds (86400 = 24 hours)
POLL_INTERVAL_SECONDS=86400

# Dry run mode — set to false to actually push to AniList
DRY_RUN=true

# Operating mode: "watch" for backup watcher, "poll" for Suwayomi→AniList
MODE=watch

# Backup directory (mounted from host — Syncthing drops .tachibk files here)
BACKUP_DIR=/app/backups
BACKUP_HOST_DIR=./backups

# Suwayomi population
POPULATE_SUWAYOMI=true
CLEAR_SUWAYOMI_FIRST=false
