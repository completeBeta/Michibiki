# Michibiki — Daily Mihon→AniList sync
#
# Suwayomi GraphQL endpoint (use "http://suwayomi:4567/api/graphql" in compose network)
SUWAYOMI_URL=http://suwayomi:4567/api/graphql

# AniList OAuth2 access token — get from https://anilist.co/api/v2/oauth/authorize
ANILIST_TOKEN=your_anilist_token_here

# Seconds between sync runs (86400 = daily)
POLL_INTERVAL_SECONDS=86400

# Set to "true" to log updates without pushing to AniList
DRY_RUN=false
